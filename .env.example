# ─────────────────────────────────────────────────────────────
#  TYPE — environment variables
#  Copy this file to `.env.local` and fill in your Supabase project values.
#  In Vercel, add these under Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Used to build absolute redirect URLs for OAuth in local dev.
# In production Vercel sets this automatically; leave as-is locally.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
